# --- API configuration ---
# Port Cloud Run injects at runtime; 8080 locally.
PORT=8080
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated list of allowed CORS origins (the web app's URL).
# Use * only for quick local testing.
CORS_ORIGIN=http://localhost:5173

# --- Supabase ---
# Get local values from `npm run db:status` (or `npx supabase status -o env`):
#   SUPABASE_URL                = API_URL
#   SUPABASE_SERVICE_ROLE_KEY   = SECRET_KEY
SUPABASE_URL=http://127.0.0.1:54321
# Secret (service-role) key — full DB access, bypasses RLS. KEEP SECRET in prod.
# Never commit a real value; paste your local SECRET_KEY here.
SUPABASE_SERVICE_ROLE_KEY=paste-local-SECRET_KEY-here
